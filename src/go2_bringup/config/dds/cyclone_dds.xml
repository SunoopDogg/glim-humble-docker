<?xml version="1.0" encoding="UTF-8" ?>
<!-- CycloneDDS configuration for Go2 EDU communication over dedicated ethernet.
     NetworkInterfaceAddress: set to the interface connected to Go2 (192.168.123.x subnet).
     Verify with: ip a   (look for the interface with 192.168.123.x address)
     Common values: eth0, enp3s0, enx<mac> -->
<CycloneDDS>
  <Domain id="0">
    <General>
      <NetworkInterfaceAddress>enx32aababacca0</NetworkInterfaceAddress>
      <AllowMulticast>true</AllowMulticast>
    </General>
  </Domain>
</CycloneDDS>
