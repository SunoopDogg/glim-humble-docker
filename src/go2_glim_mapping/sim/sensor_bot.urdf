<?xml version="1.0"?>
<!-- Decoupled mapping test rig: diff-drive base (reliable cmd_vel motion) +
     OS1-ish 32-beam spinning LiDAR + IMU. Purpose: validate GLIM map quality
     under genuine motion WITHOUT depending on quadruped locomotion tuning.
     LiDAR frame_id="lidar", IMU frame_id="imu" (GLIM auto-detects these). -->
<robot name="sensor_bot">

  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.4"/>
    </inertial>
    <collision>
      <geometry><box size="0.4 0.3 0.15"/></geometry>
    </collision>
    <visual>
      <geometry><box size="0.4 0.3 0.15"/></geometry>
    </visual>
  </link>

  <!-- drive wheels -->
  <link name="left_wheel">
    <inertial><mass value="1.0"/><origin xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.008"/></inertial>
    <collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></visual>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_wheel"/>
    <origin xyz="-0.15 0.175 -0.05"/><axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <inertial><mass value="1.0"/><origin xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.008"/></inertial>
    <collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></collision>
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.1" length="0.05"/></geometry></visual>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_wheel"/>
    <origin xyz="-0.15 -0.175 -0.05"/><axis xyz="0 1 0"/>
  </joint>

  <!-- front caster (low friction sphere) -->
  <link name="caster">
    <inertial><mass value="0.5"/><origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <visual><geometry><sphere radius="0.05"/></geometry></visual>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/><child link="caster"/>
    <origin xyz="0.15 0 -0.1"/>
  </joint>
  <gazebo reference="caster">
    <mu1>0.0</mu1><mu2>0.0</mu2>
  </gazebo>

  <!-- LiDAR -->
  <link name="lidar_link">
    <inertial><mass value="0.5"/><origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <collision><geometry><cylinder radius="0.04" length="0.07"/></geometry></collision>
    <visual><geometry><cylinder radius="0.04" length="0.07"/></geometry></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="0.1 0 0.15"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link">
    <inertial><mass value="0.05"/><origin xyz="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <!-- ===== Gazebo plugins ===== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/</namespace></ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.35</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>
      <max_wheel_torque>50</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>diff_odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- OS1-ish 32-beam spinning LiDAR (CPU ray -> headless OK). frame_name=lidar -->
  <gazebo reference="lidar_link">
    <sensor name="os1_32" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1024</samples><resolution>1</resolution>
            <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>32</samples><resolution>1</resolution>
            <min_angle>-0.3927</min_angle><max_angle>0.3927</max_angle>
          </vertical>
        </scan>
        <range><min>0.5</min><max>100.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </ray>
      <plugin name="os1_laser" filename="libgazebo_ros_velodyne_laser.so">
        <ros><namespace>/</namespace><remapping>~/out:=points</remapping></ros>
        <frame_name>lidar</frame_name>
        <organize_cloud>false</organize_cloud>
        <min_range>0.5</min_range>
        <max_range>100.0</max_range>
        <gaussian_noise>0.008</gaussian_noise>
      </plugin>
    </sensor>
  </gazebo>

  <!-- IMU 200 Hz. frame=imu -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=imu</remapping></ros>
        <frame_name>imu</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

</robot>
